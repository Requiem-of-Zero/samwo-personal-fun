# Dependency folders are installed inside the image.
node_modules/

# Next.js build output is generated inside the image.
.next/
out/
build/

# Local environment and secret files should not enter the image.
.env
.env.*
*.pem

# Logs and local tool caches do not belong in the build context.
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.cache/
.turbo/
.vercel/

# Git and editor/OS noise.
.git/
.gitignore
.DS_Store
Thumbs.db
