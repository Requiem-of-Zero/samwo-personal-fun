model RestaurantSettings {
  id               Int      @id @default(1)
  name             String
  publicUrl        String?
  logoUrl          String?
  primaryColor     String   @default("#ff6a1a")
  accentColor      String   @default("#ffd166")
  backgroundColor  String   @default("#100b0b")
  textColor        String   @default("#fff7ed")
  receiptFooter    String?
  taxRate          Decimal  @default(0)
  currency         String   @default("USD")
  timezone         String   @default("America/Los_Angeles")
  defaultLocale    String   @default("en")
  supportedLocales String[] @default(["en"])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  paymentSettings RestaurantPaymentSettings?
}
