/// Physical restaurant table that can be printed as a QR code destination.
model DiningTable {
  id        Int      @id @default(autoincrement())
  row       String
  col       Int
  label     String?
  seats     Int      @default(4)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions TableSession[]

  @@unique([row, col])
}

/// One live dining visit opened from a table QR code.
model TableSession {
  id                        Int                @id @default(autoincrement())
  tableId                   Int
  publicToken               String             @unique
  status                    TableSessionStatus @default(OPEN)
  openedAt                  DateTime           @default(now())
  attendeeCount             Int?
  orderVerificationRequired Boolean            @default(true)
  submittedAt               DateTime?
  closedAt                  DateTime?
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt

  table                     DiningTable                     @relation(fields: [tableId], references: [id])
  items                     TableSessionItem[]
  orders                    Order[]
  checkouts                 Checkout[]
  participants              TableSessionParticipant[]
  ownershipTransferRequests TableSessionOwnershipTransfer[]

  @@index([tableId, status])
}

/// One browser/device/person connected to a table session.
/// publicId is stored client-side and survives guest login/logout.
model TableSessionParticipant {
  id                         Int                         @id @default(autoincrement())
  tableSessionId             Int
  userId                     String?
  publicId                   String                      @unique
  displayName                String
  role                       TableSessionParticipantRole @default(GUEST)
  phoneNumber                String?
  phoneVerificationCodeHash  String?
  phoneVerificationExpiresAt DateTime?
  phoneVerifiedAt            DateTime?
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt

  tableSession                TableSession                    @relation(fields: [tableSessionId], references: [id], onDelete: Cascade)
  user                        User?                           @relation(fields: [userId], references: [id], onDelete: SetNull)
  requestedOrders             Order[]
  requestedOwnershipTransfers TableSessionOwnershipTransfer[] @relation("OwnershipTransferRequester")
  receivedOwnershipTransfers  TableSessionOwnershipTransfer[] @relation("OwnershipTransferTarget")

  @@unique([tableSessionId, userId])
  @@index([tableSessionId, role])
  @@index([userId])
}

/// Owner-initiated handoff; target must accept before owner role changes.
model TableSessionOwnershipTransfer {
  id                       Int                     @id @default(autoincrement())
  tableSessionId           Int
  requestedByParticipantId Int
  targetParticipantId      Int
  status                   OwnershipTransferStatus @default(PENDING)
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  respondedAt              DateTime?

  tableSession           TableSession            @relation(fields: [tableSessionId], references: [id], onDelete: Cascade)
  requestedByParticipant TableSessionParticipant @relation("OwnershipTransferRequester", fields: [requestedByParticipantId], references: [id], onDelete: Cascade)
  targetParticipant      TableSessionParticipant @relation("OwnershipTransferTarget", fields: [targetParticipantId], references: [id], onDelete: Cascade)

  @@index([tableSessionId, status])
  @@index([targetParticipantId, status])
  @@index([requestedByParticipantId])
}

/// Shared cart row before items are submitted as a kitchen/payment order.
model TableSessionItem {
  id             Int      @id @default(autoincrement())
  tableSessionId Int
  menuItemId     Int
  quantity       Int      @default(1)
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tableSession TableSession @relation(fields: [tableSessionId], references: [id], onDelete: Cascade)
  menuItem     MenuItem     @relation(fields: [menuItemId], references: [id])

  @@index([tableSessionId])
  @@index([menuItemId])
}

enum TableSessionStatus {
  OPEN
  SUBMITTED
  CHECKED_OUT
  CANCELLED
}

enum TableSessionParticipantRole {
  OWNER
  GUEST
}

enum OwnershipTransferStatus {
  PENDING
  ACCEPTED
  DENIED
  CANCELLED
}
